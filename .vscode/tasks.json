{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^([^\\s].*)\\((\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
          "file": 1,
          "location": 2,
          "severity": 3,
          "code": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "^\\s*(?:message TS6032:|.*?:\\s*error|.*?:\\s*warning)"
          },
          "endsPattern": {
            "regexp": "^\\s*(?:Found \\d+ errors?\\.|.*?:\\s*(?:error|warning)\\s+TS\\d+:\\s*.*)$"
          }
        }
      }
    }
  ]
}
